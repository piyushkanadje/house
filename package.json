{
  "name": "srushtiffarmhouse.github.io",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --force",
    "build": "npm run prepare-logo && tsc -b && vite build && node scripts/generate-sitemap.mjs && node scripts/prerender.mjs",
    "build:nopre": "npm run prepare-logo && tsc -b && vite build && node scripts/generate-sitemap.mjs",
    "prerender": "node scripts/prerender.mjs",
    "sitemap": "node scripts/generate-sitemap.mjs",
    "lint": "oxlint",
    "preview": "vite preview",
    "download-assets": "node scripts/download-assets.mjs",
    "prepare-logo": "node scripts/prepare-logo.mjs",
    "prepare-gallery": "node scripts/prepare-gallery.mjs",
    "prepare-assets": "npm run prepare-logo && npm run prepare-gallery"
  },
  "dependencies": {
    "lucide-react": "^1.21.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@sparticuz/chromium": "^149.0.0",
    "ffmpeg-static": "^5.3.0",
    "oxlint": "^1.69.0",
    "puppeteer-core": "^25.2.1",
    "tailwindcss": "^4.3.1",
    "typescript": "~6.0.2",
    "vite": "^8.1.0"
  }
}
